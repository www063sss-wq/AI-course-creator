{
  "platform": "阿里云",
  "version": "1.0.0",
  "description": "阿里云智能对话机器人配置模板",
  "bot_config": {
    "access_key_id": "YOUR_ACCESS_KEY_ID",
    "access_key_secret": "YOUR_ACCESS_KEY_SECRET",
    "instance_id": "YOUR_INSTANCE_ID",
    "knowledge_base_id": "YOUR_KB_ID"
  },
  "intent_config": {
    "enable_intent_detection": true,
    "confidence_threshold": 0.65,
    "fallback_intent": "default",
    "enable_fuzzy_match": true
  },
  "slot_filling": {
    "enable_slot_filling": true,
    "required_slots_first": true,
    "slot_prompt_template": "请告诉我您的{slot_name}"
  },
  "dialog_management": {
    "enable_multi_turn": true,
    "max_turn_count": 5,
    "enable_recommend_questions": true,
    "recommend_count": 3
  },
  "api_endpoints": {
    "chatbot_base_url": "https://chatbot.aliyuncs.com",
    "version": "2019-01-01"
  }
}
