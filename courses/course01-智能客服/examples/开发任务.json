          "name": "平台配置模板",
          "format": "JSON",
          "description": "百度智能云、阿里云、腾讯云配置模板",
          "example_file": "configs/baidu_config.json"
        },
        {
          "name": "环境变量示例",
          "format": ".env.example",
          "description": "API 密钥、数据库连接等配置",
          "example_file": ".env.example"
        }
      ]
    },
    {
      "type": "演示数据",
      "items": [
        {
          "name": "测试订单数据",
